# 🌐 SERVEUR & ENVIRONNEMENT
NODE_ENV=production
PORT=3000
LOG_LEVEL=info
BACKEND_KEEPALIVE_URL=https://votre-api.onrender.com/api/keepalive

# 🗄️ BASE DE DONNÉES (POSTGRESQL)
DB_HOST=votre-hote-db
DB_PORT=5432
DB_NAME=votre-nom-db
DB_USER=votre-utilisateur-db
DB_PASSWORD=votre-mot-de-passe-securise
DB_SSL=true

# 🔐 SÉCURITÉ & TOKENS
JWT_SECRET=votre-cle-secrete-32-chars-minimum
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=votre-cle-refresh-32-chars
JWT_REFRESH_EXPIRE=7d
QR_SECRET=votre-cle-qr-32-chars

# 📧 CONFIGURATION EMAILS
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=SG.votre-cle-sendgrid-ici
EMAIL_FROM="Nom Expéditeur <email@domaine.com>"

# Optionnel : Fallback SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre-email@gmail.com
SMTP_PASS=votre-mot-de-passe-application
SMTP_SECURE=false

# 👥 NOTIFICATIONS ADMIN
ADMIN_NOTIFICATION_EMAIL=admin@votre-domaine.com
ADMIN_NOTIFICATION_EMAIL_2=admin2@votre-domaine.com
CONTACT_ADMINS=admin@votre-domaine.com

# 🔗 URLS FRONTEND (CORS)
FRONTEND_URL=https://votre-site-public.onrender.com
FRONTEND_URL2=https://votre-admin.onrender.com
FRONTEND_LOGIN_URL=https://votre-admin.onrender.com/admin/login

# 📁 FICHIERS & MEDIA
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800
QR_CODE_SIZE=300
