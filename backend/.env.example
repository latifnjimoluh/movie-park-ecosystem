NODE_ENV=development
PORT=3000

DB_HOST=localhost
DB_PORT=5432
DB_NAME=movie
DB_USER=postgres
DB_PASSWORD=YOUR_DB_PASSWORD_HERE

# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=REPLACE_WITH_RANDOM_96_CHAR_HEX
JWT_EXPIRY=24h
JWT_EXPIRE=24h
JWT_REFRESH_SECRET=REPLACE_WITH_RANDOM_96_CHAR_HEX
JWT_REFRESH_EXPIRY=30d
JWT_REFRESH_EXPIRE=30d

# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
QR_SECRET=REPLACE_WITH_RANDOM_64_CHAR_HEX

MAX_FILE_SIZE=52428800
UPLOAD_DIR=./uploads
QR_CODE_SIZE=300
LOG_LEVEL=info
LOG_DIR=./logs
FRONTEND_URL=http://localhost:3001
FRONTEND_URL2=http://localhost:3002
